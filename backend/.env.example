# KavachX / BASCG Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Quick-start (local dev):
#   cp .env.example .env
#   python scripts/generate_dev_keys.py   # adds BASCG_SIGNING_KEY_SEED_B64
#   uvicorn app.main:app --reload

# ─── Core ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development   # development | production

# Generate a strong secret: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_use_openssl_rand_hex_32

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default – development only, no extra setup)
DATABASE_URL=sqlite+aiosqlite:///./kavachx.db

# PostgreSQL (recommended for staging / production)
# DATABASE_URL=postgresql+asyncpg://kavachx:password@localhost:5432/kavachx

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins. NEVER use * in production.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173

# ─── Auth ─────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=480
# Set to "true" ONLY in development to show demo passwords on login screen
EXPOSE_DEMO_PASSWORDS=false

# ─── Governance Thresholds ────────────────────────────────────────────────────
RISK_SCORE_HIGH_THRESHOLD=0.60
RISK_SCORE_MEDIUM_THRESHOLD=0.20
FAIRNESS_DISPARITY_THRESHOLD=0.20
CONFIDENCE_LOW_THRESHOLD=0.55

# ─── Audit ────────────────────────────────────────────────────────────────────
# Probability of emitting a random governance probe (0.0 – 1.0)
AUDIT_PROBE_PROBABILITY=0.05

# ─── Security ─────────────────────────────────────────────────────────────────
MAX_REQUEST_SIZE_KB=512
LOGIN_MAX_FAILURES=10

# ─── Display ──────────────────────────────────────────────────────────────────
DISPLAY_TIMEZONE=Asia/Kolkata


# ══════════════════════════════════════════════════════════════════════════════
#  BASCG — Bharat AI Sovereign Control Grid
# ══════════════════════════════════════════════════════════════════════════════

# ─── BASCG Provider Mode — top-level local ↔ production toggle ───────────────
# "local"      → all pillars use mock/dev providers (no network, no hardware)
# "production" → all pillars enforce real providers; hard NAEL blocking
# Individual overrides (SOVEREIGN_LEDGER_MODE, TEE_ATTESTATION_MODE, etc.)
# always take precedence when explicitly set.
BASCG_PROVIDER_MODE=local

# ─── P0: Cryptographic Signing (PolicyBundles + NAEL tokens) ──────────────────
# Generate keypair:  python scripts/generate_dev_keys.py
# Production:        replace with HSM-backed key (AWS KMS / Google Cloud HSM)
# Leave empty → ephemeral key generated at each restart (dev/CI only)
BASCG_SIGNING_KEY_SEED_B64=

# Additional trusted issuer public keys for multi-node / federated deployments.
# Format: JSON dict  {"issuer-name": "<base64-encoded-32-byte-public-key>"}
# Example: '{"MeitY-BASCG-v1": "abc123==", "RBI-AI-Gov": "xyz789=="}'
BASCG_TRUSTED_PUBLIC_KEYS_JSON={}

# ─── P0 / Phase 1: Sovereign Ledger Sync (Merkle + TSA) ───────────────────────
# Layer 4 Forensic — Merkle tree anchoring for IT Act S.65B court admissibility
SOVEREIGN_LEDGER_ENABLED=true
# "mock"       → local HMAC-signed token, no network (dev / CI)
# "rfc3161"    → live RFC 3161 HTTP request to TSA_URL (production)
# "blockchain" → EVM permissioned-chain anchor via JSON-RPC (advanced)
SOVEREIGN_LEDGER_MODE=mock

# How often to run the anchor cycle
LEDGER_ANCHOR_INTERVAL_MINUTES=5
# Minimum logs required before triggering an anchor (reduce TSA calls in prod)
LEDGER_ANCHOR_MIN_BATCH_SIZE=1

# RFC 3161 mode — any public or private TSA endpoint
# Free options: https://freetsa.org/tsr  |  http://timestamp.sectigo.com
# Paid options: https://timestamp.digicert.com
TSA_URL=https://freetsa.org/tsr

# Mock TSA HMAC key — change to any random string in dev/CI
# openssl rand -hex 32
MOCK_TSA_SECRET=CHANGE_ME_MOCK_TSA_SECRET_32CHARS

# ─── P2b: Blockchain TSA (EVM permissioned anchor) ────────────────────────────
# Only used when SOVEREIGN_LEDGER_MODE=blockchain
# RPC endpoint for Hyperledger Besu / Quorum / any EVM PoA node
SOVEREIGN_LEDGER_BLOCKCHAIN_RPC_URL=http://localhost:8545
# Unlocked PoA account — no private key required for clique/IBFT consensus
SOVEREIGN_LEDGER_BLOCKCHAIN_FROM_ADDRESS=0x0000000000000000000000000000000000000000
# Chain ID for EIP-155 replay protection (Besu dev default = 1337)
SOVEREIGN_LEDGER_BLOCKCHAIN_CHAIN_ID=1337

# ─── P1: NAEL — National AI Execution License ─────────────────────────────────
# When true, inferences on models WITHOUT a valid NAEL license are BLOCKED.
# Set false during initial rollout / onboarding migration period.
NAEL_ENFORCEMENT_ENABLED=false

# Local Bridge: auto-issue a dev NAEL license for unlicensed models when
# ENVIRONMENT=development. Set false in production to prevent auto-issuance.
NAEL_AUTO_PROVISION_DEV=true

# ─── P1: TEE Attestation ──────────────────────────────────────────────────────
# "mock"      → HMAC-signed JSON document, no hardware required (dev / CI)
# "aws-nitro" → AWS Nitro Enclave COSE_Sign1 + CBOR attestation (production)
TEE_ATTESTATION_MODE=mock

# When true, inferences on compute nodes without a valid TEE clearance are BLOCKED.
# Set false during initial rollout; flip after all nodes have attestation configured.
TEE_ENFORCEMENT_ENABLED=false

# Local Bridge: auto-generate a mock attestation clearance for sessions with
# no existing clearance, when ENVIRONMENT=development.
# Production: set false — only pre-attested nodes may run inference.
TEE_AUTO_ATTEST_DEV=true

# How long a successful TEE attestation clearance stays valid (minutes).
TEE_CLEARANCE_TTL_MINUTES=60

# ─── P3: Synthetic Media Shield ───────────────────────────────────────────────
# "mock" → deterministic SHA-256 heuristic detector, no network (dev / CI)
# "api"  → HTTP multipart POST to SYNTHETIC_MEDIA_API_URL (production)
SYNTHETIC_MEDIA_MODE=mock   # mock | api | onnx

# Primary detector endpoint (required when SYNTHETIC_MEDIA_MODE=api)
# Compatible with: Hugging Face Inference API, Hive Moderation, Sensity, or any
# REST API returning {"is_synthetic": bool, "confidence": float, "labels": [...]}
# Hugging Face example: prithivMLmods/Deepfake-Detect-Siglip2
SYNTHETIC_MEDIA_API_URL=
SYNTHETIC_MEDIA_API_KEY=

# Bridge (secondary) detector — optional, tried if primary API fails.
# Only local heuristics are used if both APIs are unavailable.
# A general-purpose vision model works well here (e.g. openai/siglip-base-patch16-224).
SYNTHETIC_MEDIA_API_URL_2=
SYNTHETIC_MEDIA_API_KEY_2=

# Local ONNX detector (SYNTHETIC_MEDIA_MODE=onnx)
# Requires: pip install onnxruntime pillow
# Model contract: float32 [1,3,H,W] input → [1,2] logits or [1,1] sigmoid output
SYNTHETIC_MEDIA_ONNX_MODEL_PATH=
SYNTHETIC_MEDIA_ONNX_INPUT_NAME=input
SYNTHETIC_MEDIA_ONNX_INPUT_SIZE=224

# Flag scans above this confidence as synthetic (0.0 – 1.0)
SYNTHETIC_MEDIA_CONFIDENCE_THRESHOLD=0.65

# Election Protection Mode — escalates synthetic detections to BASCG ECI bus
# Enable during active election windows; set state to 2-letter code (e.g. MH)
ELECTION_PROTECTION_ENABLED=false
ELECTION_PROTECTION_STATE=

# ─── Multi-node Policy Consensus (T3-B) ───────────────────────────────────────
# Enable the consensus API and vote processing
CONSENSUS_ENABLED=false
# Unique identifier for this node in the consensus ring
CONSENSUS_NODE_ID=local-node
# Fraction of received votes that must be "accept" for quorum (0.0–1.0)
CONSENSUS_QUORUM_THRESHOLD=0.67
# Minimum number of votes before a tally is valid
CONSENSUS_MIN_VOTES=2
# Hours before an unresolved proposal is automatically expired
CONSENSUS_PROPOSAL_TTL_HOURS=72
# When true, vote signatures are verified against trusted Ed25519 keys
CONSENSUS_VERIFY_VOTE_SIGNATURES=true

# ─── ECI Election Integrity Webhook (T2-D) ────────────────────────────────────
# "stub"  → log-only, no network required (dev / CI default)
# "http"  → sign payload with BASCG Ed25519 key and POST to ECI_WEBHOOK_URL
ECI_WEBHOOK_MODE=stub

# Full endpoint URL of the ECI Election Integrity Bus (required when mode=http)
# Example: https://integrity-bus.eci.gov.in/api/v1/escalations
ECI_WEBHOOK_URL=
ECI_WEBHOOK_API_KEY=
ECI_WEBHOOK_TIMEOUT_SECONDS=10

# ─── Registry Federation (T2-A) + Bidirectional Sync (T3-A) ──────────────────
# URL of the national BASCG node.  Empty = local-only / no federation.
# Production example: https://bascg.meity.gov.in
BASCG_NATIONAL_NODE_URL=
BASCG_FEDERATION_TIMEOUT_SECONDS=10

# ─── NAIR-I Bidirectional Sync (T3-A) ─────────────────────────────────────────
# Set true to enable periodic background pull from the national node
NAIR_SYNC_ENABLED=false
# How often to run the full bidirectional sync cycle (minutes)
NAIR_SYNC_INTERVAL_MINUTES=30
# Entries fetched per page when pulling from the national node
NAIR_PULL_PAGE_SIZE=100
# Verify Ed25519 signature on each pulled entry (recommended: true)
NAIR_PULL_VERIFY_SIGNATURES=true

# ─── Distributed TEE Attestation (T3-C) ───────────────────────────────────────
# Set true to enable peer-challenge API and background worker
TEE_DISTRIBUTED_ENABLED=false
# Comma-separated list of peer node base URLs to challenge periodically
# Example: https://node-b.example.in,https://node-c.example.in
TEE_PEER_NODES=
# HTTP timeout for challenge / respond calls to peer nodes (seconds)
TEE_DISTRIBUTED_CHALLENGE_TIMEOUT_SECONDS=10
# How often the background worker re-challenges all configured peers (minutes)
TEE_AUTO_CHALLENGE_INTERVAL_MINUTES=60

# ─── Legal Bundle Export (T3-D) ───────────────────────────────────────────────
# Enable the legal bundle export API (/api/v1/legal-export/*)
# Bundles are court-admissible evidence packages under IT Act S.65B (India)
LEGAL_EXPORT_ENABLED=true
# Ed25519-sign every exported bundle for non-repudiation (recommended: true)
LEGAL_EXPORT_SIGN_BUNDLES=true
# Include raw TEE attestation documents (base64) in bundles — can be large
LEGAL_EXPORT_INCLUDE_RAW_DOCUMENTS=false
# Maximum audit logs per bundle (safety cap to prevent runaway memory usage)
LEGAL_EXPORT_MAX_AUDIT_LOGS=1000
